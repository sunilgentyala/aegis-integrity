# AEGIS environment variables
# Copy to .env and edit before running

# Directory where corpus index files are stored (persists between runs)
AEGIS_INDEX_DIR=./aegis_index

# Directory where analysis reports (JSON/HTML) are written
AEGIS_REPORT_DIR=./aegis_reports

# PyTorch device: cpu | cuda | mps
AEGIS_DEVICE=cpu

# Email address for Crossref polite-pool API requests (required by Crossref ToS)
AEGIS_CITATION_EMAIL=your-email@example.com
